generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  STUDENT
  LABORATORY_STAFF
}

enum UserStatus {
  ACTIVE
  DEACTIVATED
}

enum LaboratoryStatus {
  AVAILABLE
  UNAVAILABLE
  MAINTENANCE
}

enum ScheduleStatus {
  AVAILABLE
  BLOCKED
  CLOSED
}

enum ReservationStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
  COMPLETED
}

enum ReservationType {
  LAB
  PC
}

enum PCStatus {
  AVAILABLE
  OCCUPIED
  MAINTENANCE
}

enum CalendarEventType {
  MAINTENANCE
  HOLIDAY
}

enum NotificationChannel {
  EMAIL
  IN_APP
}

enum NotificationType {
  RESERVATION_CREATED
  RESERVATION_CONFIRMED
  RESERVATION_CANCELLED
  RESERVATION_REMINDER
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
}

model User {
  id                   Int             @id @default(autoincrement())
  firstName            String
  lastName             String
  email                String          @unique
  passwordHash         String
  role                 UserRole
  status               UserStatus      @default(ACTIVE)
  studentNumber        String?         @unique
  department           String?
  yearLevel            Int?
  phone                String?
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
  reservations         Reservation[]   @relation("ReservationStudent")
  reviewedReservations Reservation[]   @relation("ReservationReviewer")
  createdSchedules     Schedule[]      @relation("ScheduleCreator")
  createdCalendarEvents CalendarEvent[] @relation("CalendarEventCreator")
  assignedLaboratories Laboratory[]    @relation("LaboratoryCustodian")
  activityLogs         ActivityLog[]
  passwordResetTokens  PasswordResetToken[]
  notifications        Notification[]

  @@index([role, status])
}

model Laboratory {
  id            Int              @id @default(autoincrement())
  name          String
  roomCode      String           @unique
  building      String
  location      String?
  capacity      Int
  computerCount Int
  description   String
  status        LaboratoryStatus @default(AVAILABLE)
  imageUrl      String?          @db.LongText
  custodianId   Int?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  schedules     Schedule[]
  reservations  Reservation[]
  custodian     User?            @relation("LaboratoryCustodian", fields: [custodianId], references: [id], onDelete: SetNull)
  pcs           PC[]
  activityLogs  ActivityLog[]
  calendarEvents CalendarEvent[]

  @@index([status])
  @@index([custodianId])
  @@index([building, status])
}

model Schedule {
  id           Int            @id @default(autoincrement())
  laboratoryId Int
  date         DateTime
  startTime    String
  endTime      String
  status       ScheduleStatus @default(AVAILABLE)
  createdById  Int
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  laboratory   Laboratory     @relation(fields: [laboratoryId], references: [id], onDelete: Cascade)
  createdBy    User           @relation("ScheduleCreator", fields: [createdById], references: [id])
  reservations Reservation[]

  @@index([laboratoryId, date])
  @@index([createdById])
}

model Reservation {
  id              Int               @id @default(autoincrement())
  reservationCode String            @unique
  studentId       Int
  laboratoryId    Int
  scheduleId      Int?
  pcId            Int?
  reservationType ReservationType   @default(LAB)
  purpose         String
  reservationDate DateTime
  startTime       String
  endTime         String
  status          ReservationStatus @default(PENDING)
  remarks         String?
  reviewedById    Int?
  reviewedAt      DateTime?
  cancelledAt     DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  student         User              @relation("ReservationStudent", fields: [studentId], references: [id])
  laboratory      Laboratory        @relation(fields: [laboratoryId], references: [id], onDelete: Cascade)
  schedule        Schedule?         @relation(fields: [scheduleId], references: [id], onDelete: SetNull)
  reviewedBy      User?             @relation("ReservationReviewer", fields: [reviewedById], references: [id])
  pc              PC?               @relation(fields: [pcId], references: [id], onDelete: SetNull)
  notifications   Notification[]

  @@index([studentId, reservationDate])
  @@index([laboratoryId, reservationDate])
  @@index([status, reservationDate])
  @@index([pcId, reservationDate])
}

model PC {
  id           Int          @id @default(autoincrement())
  laboratoryId Int
  pcNumber     String
  status       PCStatus     @default(AVAILABLE)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  laboratory   Laboratory   @relation(fields: [laboratoryId], references: [id], onDelete: Cascade)
  reservations Reservation[]
  activityLogs ActivityLog[]
  calendarEvents CalendarEvent[]

  @@unique([laboratoryId, pcNumber])
  @@index([laboratoryId, status])
}

model ActivityLog {
  id          Int       @id @default(autoincrement())
  userId      Int?
  labId       Int?
  pcId        Int?
  action      String
  entityType  String
  entityId    Int?
  description String
  metadata    Json?
  timestamp   DateTime  @default(now())
  createdAt   DateTime  @default(now())
  user        User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  laboratory  Laboratory? @relation(fields: [labId], references: [id], onDelete: SetNull)
  pc          PC?       @relation(fields: [pcId], references: [id], onDelete: SetNull)

  @@index([action])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@index([labId, timestamp])
  @@index([pcId, timestamp])
  @@index([timestamp])
}

model PasswordResetToken {
  id         Int      @id @default(autoincrement())
  userId     Int
  tokenHash  String   @unique
  expiresAt  DateTime
  usedAt     DateTime?
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

model CalendarEvent {
  id           Int               @id @default(autoincrement())
  title        String
  type         CalendarEventType
  laboratoryId Int?
  pcId         Int?
  date         DateTime
  startTime    String?
  endTime      String?
  description  String?
  createdById  Int
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  laboratory   Laboratory?       @relation(fields: [laboratoryId], references: [id], onDelete: SetNull)
  pc           PC?               @relation(fields: [pcId], references: [id], onDelete: SetNull)
  createdBy    User              @relation("CalendarEventCreator", fields: [createdById], references: [id])

  @@index([date, type])
  @@index([laboratoryId, date])
  @@index([createdById])
}

model Notification {
  id            Int                @id @default(autoincrement())
  userId        Int
  reservationId Int?
  channel       NotificationChannel
  type          NotificationType
  status        NotificationStatus @default(PENDING)
  subject       String
  message       String             @db.LongText
  metadata      Json?
  readAt        DateTime?
  sentAt        DateTime?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  user          User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  reservation   Reservation?       @relation(fields: [reservationId], references: [id], onDelete: Cascade)

  @@unique([userId, reservationId, channel, type])
  @@index([userId, channel, createdAt])
  @@index([channel, status, createdAt])
  @@index([reservationId, type])
}
